DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-development-guild-id
MONGODB_URI=mongodb://localhost:27017/fernn

# Cloudflare R2 (S3-compatible API) — guild icon library storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-api-token-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-api-token-secret
R2_BUCKET_NAME=your-bucket-name
# Optional: override endpoint (default https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
# R2_ENDPOINT=
